// Closures and higher-order functions.

fn apply(f: fn(i64) -> i64, x: i64) -> i64 { f(x) }

fn map_vec(xs: Vec, f: fn(i64) -> i64) -> Vec {
    let mut out = Vec();
    for x in xs { out.push(f(x)); }
    out
}

fn main() {
    let inc = |x| x + 1;
    let sq  = |x| x * x;

    println(apply(inc, 41));         // 42
    println(map_vec(Vec(1, 2, 3, 4), sq));  // [1, 4, 9, 16]
}
