{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lumen",
  "scopeName": "source.lumen",
  "fileTypes": ["lm"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#function-decl" },
    { "include": "#method-decl" },
    { "include": "#type-decl" },
    { "include": "#function-call" },
    { "include": "#method-call" },
    { "include": "#path" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.triple-slash.lumen",
          "begin": "///",
          "end": "$",
          "patterns": [{ "include": "#comment-tags" }]
        },
        {
          "name": "comment.line.double-slash.lumen",
          "begin": "//",
          "end": "$",
          "patterns": [{ "include": "#comment-tags" }]
        },
        {
          "name": "comment.block.lumen",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" },
            { "include": "#comment-tags" }
          ]
        }
      ]
    },
    "comment-tags": {
      "patterns": [
        {
          "name": "keyword.other.todo.lumen",
          "match": "\\b(TODO|FIXME|XXX|NOTE|HACK|BUG)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.lumen",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.lumen",
          "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|[nrt\\\\'\"0]|.)"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.lumen",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.lumen",
          "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|[nrt\\\\'\"0]|.)"
        }
      ]
    },
    "attributes": {
      "name": "meta.attribute.lumen",
      "begin": "#\\[",
      "end": "\\]",
      "patterns": [
        { "include": "#strings" },
        { "include": "#numbers" },
        {
          "name": "entity.name.tag.lumen",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lumen",
          "match": "\\b(if|else|switch|case|default|match|for|in|while|loop|break|continue|return|defer|select|spawn)\\b"
        },
        {
          "name": "keyword.other.lumen",
          "match": "\\b(use|mod|package|import|pub|as|where|extern|comptime|move)\\b"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "name": "storage.type.function.lumen",
          "match": "\\b(func|fn)\\b"
        },
        {
          "name": "storage.type.lumen",
          "match": "\\b(struct|enum|trait|impl|type|chan)\\b"
        },
        {
          "name": "storage.modifier.lumen",
          "match": "\\b(let|var|const|mut)\\b"
        },
        {
          "name": "variable.language.self.lumen",
          "match": "\\b(self|Self)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lumen",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.lumen",
          "match": "\\b(nil|null|None)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.lumen",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*([eE][+-]?\\d+)?(f32|f64)?\\b"
        },
        {
          "name": "constant.numeric.hex.lumen",
          "match": "\\b0x[0-9A-Fa-f_]+(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int|uint)?\\b"
        },
        {
          "name": "constant.numeric.oct.lumen",
          "match": "\\b0o[0-7_]+(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int|uint)?\\b"
        },
        {
          "name": "constant.numeric.bin.lumen",
          "match": "\\b0b[01_]+(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int|uint)?\\b"
        },
        {
          "name": "constant.numeric.integer.lumen",
          "match": "\\b\\d[\\d_]*(i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|int|uint|int64|uint64)?\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.lumen",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|i8|i16|i32|i64|u8|u16|u32|u64|isize|usize|float32|float64|f32|f64|bool|char|string|str|byte|rune|unit|void)\\b"
        },
        {
          "name": "entity.name.type.lumen",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "function-decl": {
      "begin": "\\b(func|fn)\\b\\s+(?:\\(\\s*[^)]*\\)\\s+)?([a-z_][A-Za-z0-9_]*)",
      "beginCaptures": {
        "1": { "name": "storage.type.function.lumen" },
        "2": { "name": "entity.name.function.lumen" }
      },
      "end": "(?=\\(|\\{|$)"
    },
    "method-decl": {
      "match": "\\b(func|fn)\\b\\s+(\\([^)]+\\))\\s+([a-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.function.lumen" },
        "3": { "name": "entity.name.function.lumen" }
      }
    },
    "type-decl": {
      "match": "\\b(type)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.lumen" },
        "2": { "name": "entity.name.type.lumen" }
      }
    },
    "function-call": {
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.lumen" }
      }
    },
    "method-call": {
      "match": "(\\.)([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "punctuation.accessor.lumen" },
        "2": { "name": "entity.name.function.method.lumen" }
      }
    },
    "path": {
      "patterns": [
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(::)\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.lumen" },
            "2": { "name": "punctuation.separator.path.lumen" },
            "3": { "name": "variable.other.enummember.lumen" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.lumen",
          "match": ":=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|="
        },
        {
          "name": "keyword.operator.comparison.lumen",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.lumen",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.lumen",
          "match": "<<|>>|\\^|~|\\||&"
        },
        {
          "name": "keyword.operator.arrow.lumen",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.range.lumen",
          "match": "\\.\\.=|\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.lumen",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.reference.lumen",
          "match": "&"
        },
        {
          "name": "keyword.operator.question.lumen",
          "match": "\\?"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.path.lumen",
          "match": "::"
        },
        {
          "name": "punctuation.accessor.lumen",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.comma.lumen",
          "match": ","
        },
        {
          "name": "punctuation.terminator.lumen",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.lumen",
          "match": ":"
        },
        {
          "name": "punctuation.section.braces.lumen",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.brackets.lumen",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.parens.lumen",
          "match": "[()]"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.language.placeholder.lumen",
          "match": "\\b_\\b"
        },
        {
          "name": "variable.other.lumen",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
