// Benchmark: encode 5,000,000 JSON records to stdout.
// Same shape as benchmarks/programs/json_encode.c — byte-for-byte identical
// output. Stdout switched to a 1 MiB fully-buffered allocation via the
// `io_setbuf` runtime builtin so per-call printf cost is amortized.

func main() {
    i := 0
    for i < 5000000 {
        println(fmt("{\"id\":{},\"name\":\"alice\",\"active\":true,\"score\":3.14}", i))
        i = i + 1
    }
}
